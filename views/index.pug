extends layout

block content
  h1 Welcome to 
    em #{title}
  p Explore our delicious menu, learn about our business, and place your order today!
  hr
  .button-group
    form(method='GET' action='/menu')
      label(for='menu') View Menu:
      button(type='submit')  Menu
    form(method='GET' action='/about')
      label(for='about') About Us:
      button(type='submit') About
    form(method='GET' action='/order')
      label(for='order') Place an Order:
      button(type='submit') Order

  hr 

  form#submit-comment(action="/submit-comment" method="POST")
    label(for="user-comment") Leave a comment:
    br
    textarea#user-comment(
      name="comment" 
      rows="4" 
      cols="50" 
      placeholder="Type your thoughts here..." 
      required
    )
    br
    input(type="submit" value="Submit")
  
  #comments-list.comments-container
    each val in comments
      .comment-item
        span= val.body 
        span= " - " + val.written
     
  button#load-more(type="button" style=hasMore ? '' : 'display: none;') Load More Comments

  script.
    let offset = !{comments.length};
    const limit = 10;
    const loadMoreBtn = document.getElementById('load-more');
    const commentsList = document.getElementById('comments-list');

    loadMoreBtn.addEventListener('click', function() {
      fetch('/comments?limit=' + limit + '&offset=' + offset)
        .then(response => response.json())
        .then(data => {
          if (data.error) {
            console.error(data.error);
            return;
          }
          data.comments.forEach(comment => {
            const commentDiv = document.createElement('div');
            commentDiv.className = 'comment-item';
            commentDiv.innerHTML = '<span>' + comment.body + '</span><span> - ' + comment.written + '</span>';
            commentsList.appendChild(commentDiv);
          });
          offset += limit;
          if (!data.hasMore) {
            loadMoreBtn.style.display = 'none';
          }
        })
        .catch(error => console.error('Error loading more comments:', error));
    });
